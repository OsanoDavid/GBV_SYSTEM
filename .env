# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Email Configuration (for local development)
# Development uses console backend - emails print to terminal
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For Production on Render: OPTION 1 - Gmail App Password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password

# For Production on Render: OPTION 2 - SendGrid (Recommended)
# SENDGRID_API_KEY=your-sendgrid-api-key

DEFAULT_FROM_EMAIL=SafeSpace System <no-reply@safespace.org>

# SMS Configuration
# Priority 1: Twilio (uncomment to use)
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_FROM_NUMBER=+1234567890

# Priority 2: Custom SMS Provider (Africa's Talking, Nexmo, etc.)
# SMS_API_URL=https://your-sms-provider.com/send
# SMS_API_KEY=your-api-key
# SMS_SENDER_ID=SafeSpace

# If both are commented out, SMS will log to console (development mode)

# Security
SECURE_SSL_REDIRECT=False
